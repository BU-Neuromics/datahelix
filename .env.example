# DataHelix Platform — Environment Configuration
# Copy to .env and fill in values:  cp .env.example .env
# NEVER commit the .env file to version control.

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=datahelix
POSTGRES_PASSWORD=          # REQUIRED — set a strong password
POSTGRES_DB=datahelix

# ── Bridge gateway ──────────────────────────────────────────
BRIDGE_PORT=8080
BRIDGE_JWT_KEY=             # Generate: python -c "import secrets; print(secrets.token_hex(32))"
BRIDGE_LOCAL_ADMIN_PW=      # Admin password for local auth provider

# ── Inter-service tokens ────────────────────────────────────
# Used by Canon and Cappella to authenticate with Mosaic via Bridge.
CANON_SERVICE_TOKEN=        # Generate: python -c "import secrets; print(secrets.token_hex(32))"
CAPPELLA_SERVICE_TOKEN=     # Generate: python -c "import secrets; print(secrets.token_hex(32))"
